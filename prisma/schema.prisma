generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String?              @unique @db.VarChar(255)
  provider            String               @db.VarChar(20)
  oauthId             String               @map("oauth_id") @db.VarChar(255)
  name                String               @db.VarChar(50)
  refreshToken        String?              @map("refresh_token") @db.Text
  onboardingCompleted Boolean              @default(false) @map("onboarding_completed")
  createdAt           DateTime             @default(now()) @map("created_at")
  activities          UserActivity[]
  goalPeriods         GoalPeriod[]
  notificationLogs    NotificationLog[]
  notificationSetting NotificationSetting?
  profile             UserProfile?
  calendar            CalendarSetting?
  pushTokens          PushToken[]
  reminders           Reminder[]
  reports             Report[]

  @@unique([provider, oauthId])
  @@map("user")
}

model UserActivity {
  id             Int         @id @default(autoincrement())
  userId         Int         @map("user_id")
  googleEventId  String?     @unique @map("google_event_id") @db.VarChar(255)
  title          String      @db.VarChar(200)
  startAt        DateTime    @map("start_at")
  endAt          DateTime    @map("end_at")
  category       ActivityTab @default(GROWTH)
  type           String      @default("FIXED") @db.VarChar(20)
  status         String      @default("TODO") @db.VarChar(20)
  eventColor     Int         @default(1) @map("event_color") // 로컬 성공 필드 추가
  recurrenceRule String?     @map("recurrence_rule")         // 로컬 성공 필드 추가
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_activity")
}

model activity {
  id               Int           @id @default(autoincrement())
  title            String
  tab              activity_tab
  point            Int
  thumbnailUrl     String?       @map("thumbnail_url") @db.VarChar(2048)
  description      String?       @db.Text
  type             activity_type @default(NORMAL)
  startDate        DateTime?     @map("start_date")
  endDate          DateTime?     @map("end_date")
  recruit_end_date DateTime?     @map("recruit_end_date")
  organizer        String?       @db.VarChar(100)
  tags             Json?
  externalUrl      String?       @map("external_url") @db.VarChar(2048)
  categoryId       Int?          @map("category_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  CartItems        cartitem[]
  MyActivities     myactivity[]

  @@index([categoryId], map: "Activity_categoryId_idx")
  @@index([tab], map: "Activity_tab_idx")
  @@map("activity") // 서버 DB 테이블명(소문자)과 매핑
}

model cartitem {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  activityId Int      @map("activity_id")
  createdAt  DateTime @default(now()) @map("created_at")
  activity   activity @relation(fields: [activityId], references: [id])

  @@unique([userId, activityId], map: "CartItem_userId_activityId_key")
  @@index([activityId], map: "CartItem_activityId_fkey")
  @@index([userId], map: "CartItem_userId_idx")
  @@map("cartitem")
}

model myactivity {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  goalId     Int      @map("goal_id")
  activityId Int      @map("activity_id")
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  point      Int
  createdAt  DateTime @default(now()) @map("created_at")
  activity   activity @relation(fields: [activityId], references: [id])

  @@index([activityId], map: "MyActivity_activityId_fkey")
  @@index([goalId], map: "MyActivity_goalId_idx")
  @@index([userId], map: "MyActivity_userId_idx")
  @@map("myactivity")
}

model GoalPeriod {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  title      String   @db.VarChar(100)
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  growth     Int
  rest       Int
  presetType String   @default("CUSTOM") @map("preset_type") @db.VarChar(20)
  presetId   Int?     @map("preset_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports    Report[]

  @@index([userId])
  @@map("goal_period")
}

model NotificationSetting {
  id                        Int      @id @default(autoincrement())
  userId                    Int      @unique @map("user_id")
  dDayEnabled               Boolean  @default(true) @map("d_day_enabled")
  activityCompletionEnabled Boolean  @default(true) @map("activity_completion_enabled")
  fcmToken                  String?  @map("fcm_token") @db.VarChar(255)
  updatedAt                 DateTime @updatedAt @map("updated_at")
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_setting")
}

model UserProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  interests Json
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile")
}

model CalendarSetting {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique @map("user_id")
  connect              Boolean  @default(false)
  provider             String?  @db.VarChar(20)
  importFixedSchedules Boolean  @default(false) @map("import_fixed_schedules")
  selectedEventIds     Json?    @map("selected_event_ids")
  manualFixedSchedules Json?    @map("manual_fixed_schedules")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_setting")
}

model Reminder {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  reminderType String   @map("reminder_type") @db.VarChar(50)
  isEnabled    Boolean  @default(true) @map("is_enabled")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("reminder")
}

model PushToken {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  token       String   @unique @db.VarChar(255)
  platform    String   @db.VarChar(20)
  environment String   @db.VarChar(20)
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_token")
}

model Interest {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  @@map("interest")
}

model Report {
  id         Int        @id @default(autoincrement())
  userId     Int
  goalId     Int        @map("goal_id")
  type       String     @db.VarChar(20)
  title      String?    @db.VarChar(100)
  subTitle   String?    @db.VarChar(255)
  createdAt  DateTime   @default(now()) @map("created_at")
  growth     Int
  rest       Int
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalPeriod GoalPeriod @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId])
  @@map("report")
}

model NotificationLog {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  type     String   @db.VarChar(50)
  refType  String   @db.VarChar(50)
  refId    Int      @map("ref_id")
  sendDate DateTime @map("send_date")
  sentAt   DateTime @default(now()) @map("sent_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, refType, refId, sendDate])
  @@index([userId])
  @@map("notification_log")
}

enum ActivityTab {
  GROWTH
  REST
}

enum activity_tab {
  GROWTH
  REST
}

enum activity_type {
  NORMAL
  CONTEST
}