generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                  Int      @id @default(autoincrement())
  email               String?  @unique @db.VarChar(255)
  provider            String   @db.VarChar(20)
  oauthId             String   @map("oauth_id") @db.VarChar(255)
  name                String   @db.VarChar(50)
  refreshToken        String?  @map("refresh_token") @db.Text
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")

  // 관계 정의
  calendar            CalendarSetting?
  goalPeriods         GoalPeriod[]
  notificationLogs    NotificationLog[]
  notificationSetting NotificationSetting?
  pushTokens          PushToken[]
  reminders           Reminder[]
  reports             Report[]
  activities          UserActivity[]
  profile             UserProfile?

  @@unique([provider, oauthId])
  @@map("user")
}

model ActivityCatalog {
  id             Int          @id @default(autoincrement())
  title          String
  tab            ActivityTab
  point          Int
  thumbnailUrl   String?      @db.VarChar(2048)
  description    String?      @db.Text
  type           ActivityType @default(NORMAL)
  startDate      DateTime?
  endDate        DateTime?
  recruitEndDate DateTime?    @map("recruit_end_date")
  organizer      String?      @db.VarChar(100)
  tags           Json?
  externalUrl    String?      @db.VarChar(2048)
  categoryId     Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  CartItem       CartItem[]
  MyActivity     MyActivity[]
  activityInterests ActivityInterest[]


  @@index([tab])
  @@index([categoryId])
  @@map("Activity")
}

model UserActivity {
  id            Int         @id @default(autoincrement())
  userId        Int         @map("user_id")
  googleEventId String?     @unique @map("google_event_id") @db.VarChar(255)
  title         String      @db.VarChar(200)
  startAt       DateTime    @map("start_at")
  endAt         DateTime    @map("end_at")
  category      ActivityTab @default(GROWTH)
  type          String      @default("FIXED") @db.VarChar(20)
  status        String      @default("TODO") @db.VarChar(20)
  eventColor     Int         @default(1) @map("event_color")
  recurrenceRule String?     @map("recurrence_rule")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_user_activity_user")

  @@index([userId])
  @@map("user_activity")
}

model CalendarSetting {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique @map("user_id")
  connect              Boolean  @default(false)
  provider             String?  @db.VarChar(20)
  importFixedSchedules Boolean  @default(false) @map("import_fixed_schedules")
  selectedEventIds     Json?    @map("selected_event_ids")
  manualFixedSchedules Json?    @map("manual_fixed_schedules")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_calendar_user")

  @@map("calendar_setting")
}

model GoalPeriod {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  title      String   @db.VarChar(100)
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  growth     Int
  rest       Int
  presetType String   @default("CUSTOM") @map("preset_type") @db.VarChar(20)
  presetId   Int?
  createdAt  DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_goal_period_user")
  reports    Report[]

  @@index([userId])
  @@map("goal_period")
}

model UserProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  interests Json
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "user_profile_user_fkey")

  @@map("user_profile")
}

model NotificationSetting {
  id                        Int      @id @default(autoincrement())
  userId                    Int      @unique @map("user_id")
  dDayEnabled               Boolean  @default(true) @map("d_day_enabled")
  activityCompletionEnabled Boolean  @default(true) @map("activity_completion_enabled")
  fcmToken                  String?  @map("fcm_token") @db.VarChar(255)
  updatedAt                 DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_notif_setting_user")

  @@map("notification_setting")
}

model Reminder {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  reminderType String   @map("reminder_type") @db.VarChar(50)
  isEnabled    Boolean  @default(true) @map("is_enabled")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "reminder_user_fkey")

  @@unique([userId, reminderType])
  @@index([userId])
  @@map("reminder")
}

model PushToken {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  token       String   @unique @db.VarChar(255)
  platform    String   @db.VarChar(20)
  environment String   @db.VarChar(20)
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "push_token_user_fkey")

  @@index([userId])
  @@map("push_token")
}

model Interest {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)
  activityInterests ActivityInterest[]


  @@map("interest")
}

model Report {
  id         Int        @id @default(autoincrement())
  userId     Int
  goalId     Int
  type       String     @db.VarChar(20)
  title      String?    @db.VarChar(100)
  subTitle   String?    @db.VarChar(255)
  createdAt  DateTime   @default(now()) @map("created_at")
  growth     Int
  rest       Int
  goalPeriod GoalPeriod @relation(fields: [goalId], references: [id], onDelete: Cascade, map: "fk_report_goal_period")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_report_user")

  @@index([userId])
  @@index([goalId])
  @@map("report")
}

model NotificationLog {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  type     String   @db.VarChar(50)
  refType  String   @db.VarChar(50)
  refId    Int      @map("ref_id")
  sendDate DateTime @map("send_date")
  sentAt   DateTime @default(now()) @map("sent_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "notif_log_user_fkey")

  @@unique([userId, type, refType, refId, sendDate])
  @@index([userId])
  @@map("notification_log")
}

model CartItem {
  id         Int             @id @default(autoincrement())
  userId     Int
  activityId Int
  createdAt  DateTime        @default(now())
  Activity ActivityCatalog @relation(fields: [activityId], references: [id], map: "fk_cart_item_activity")

  @@unique([userId, activityId])
  @@index([activityId], map: "CartItem_activity_catalog_idx")
  @@index([userId])
}

model MyActivity {
  id         Int             @id @default(autoincrement())
  userId     Int
  goalId     Int
  activityId Int
  startDate  DateTime
  endDate    DateTime
  point      Int
  createdAt  DateTime        @default(now())
  Activity ActivityCatalog @relation(fields: [activityId], references: [id], map: "fk_my_activity_activity")

  @@index([activityId], map: "MyActivity_activity_catalog_idx")
  @@index([goalId])
  @@index([userId])
}

enum ActivityTab {
  GROWTH
  REST
}

enum ActivityType {
  NORMAL
  CONTEST
}
model ActivityInterest {
  activityId Int
  interestId Int

  activity ActivityCatalog @relation(fields: [activityId], references: [id])
  interest Interest        @relation(fields: [interestId], references: [id])

  @@id([activityId, interestId])
  @@index([interestId])
  @@index([activityId])
}

